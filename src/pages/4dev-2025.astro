---
import favicon from "../img/4dev-logo.png";
import qrCodeRating from "../img/qrcode_rating_4dev.png";
import qrCodeLink from "../img/qrcode_talk_4dev_roma.png";
import Layout from "../layouts/Layout.astro";
import Conclusions from "../slides/conclusions.astro";
import CoverFourDev from "../slides/cover-four-dev.astro";
import Cover from "../slides/cover.astro";
import CustomElements from "../slides/custom-elements.astro";
import DeepDiveLit from "../slides/deep-dive-lit.astro";
import DesignSystem from "../slides/design-system.astro";
import IntegrationAngular from "../slides/integration-angular.astro";
import IntegrationVanilla from "../slides/integration-vanilla.astro";
import Intro from "../slides/intro.astro";
import MeetLit from "../slides/meet-lit.astro";
import ProblemWithFramework from "../slides/problem-with-framework.astro";
import Sponsor4Dev from "../slides/sponsor-4dev.astro";
import ThanksWithLayout from "../slides/thanks-with-layout.astro";
import Webcomponent from "../slides/webcomponent.astro";

const favIcon = favicon.src;
const canRender = import.meta.env.DEV || new Date("2025-10-03") < new Date();
const metaData = {
  title: "Framework-Agnostic Design Systems: Using Lit Web Components",
  description: "Talk di Marco Pollacci",
  image: "og-image.png",
  site: "https://talk-framework-agnostic-component-with-lit.pages.dev/4dev-2025",
};
---

<Layout {canRender} {favIcon} {metaData} wrapper="4dev">
  <CoverFourDev />
  {
    canRender && (
      <>
        <Sponsor4Dev />
        <Cover />
        <Intro />
        <DesignSystem />
        <ProblemWithFramework />
        <Webcomponent />
        <MeetLit />
        <DeepDiveLit />
        <IntegrationVanilla />
        <IntegrationAngular />
        <CustomElements />
        <Conclusions />
        <ThanksWithLayout
          qrLinkRating={qrCodeRating}
          qrLink={qrCodeLink}
          urlLink={metaData.site}
        />
      </>
    )
  }
</Layout>
